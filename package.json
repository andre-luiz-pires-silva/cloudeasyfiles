{
  "name": "cloudeasyfiles",
  "private": true,
  "version": "0.2.0",
  "description": "Desktop file explorer for cloud storage.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:frontend": "npm run build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:frontend": "vitest run",
    "test:frontend:coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=json-summary --coverage.reporter=html",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:rust:coverage": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --json --summary-only --output-path coverage/rust-coverage.json && node ./scripts/check-rust-coverage.mjs",
    "test": "npm run test:frontend && npm run test:rust",
    "check": "npm run check:frontend && npm run check:rust",
    "prepare": "git config core.hooksPath .githooks || true",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.0.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@tauri-apps/cli": "2.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  }
}
