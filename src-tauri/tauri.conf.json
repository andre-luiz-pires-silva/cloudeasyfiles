{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloudEasyFiles",
  "version": "0.1.0",
  "identifier": "com.andre.cloudeasyfiles",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "enableGTKAppId": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "CloudEasyFiles",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Unified desktop file explorer for cloud storage.",
    "category": "DeveloperTool",
    "linux": {
      "deb": {
        "desktopTemplate": "linux/desktop-template.hbs",
        "files": {
          "/usr/share/applications/com.andre.cloudeasyfiles.desktop": "linux/com.andre.cloudeasyfiles.desktop"
        }
      },
      "rpm": {
        "desktopTemplate": "linux/desktop-template.hbs",
        "files": {
          "/usr/share/applications/com.andre.cloudeasyfiles.desktop": "linux/com.andre.cloudeasyfiles.desktop"
        }
      }
    }
  }
}
