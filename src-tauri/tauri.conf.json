{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloudEasyFiles",
  "version": "0.1.0",
  "identifier": "com.andre.cloudeasyfiles",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "CloudEasyFiles",
        "width": 1200,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Unified desktop file explorer for AWS S3 and Azure Blob Storage.",
    "category": "DeveloperTool"
  }
}
